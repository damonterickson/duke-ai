# WARNING: EXPO_PUBLIC_ vars are embedded in the app bundle and visible to users.
# For production, use a server-side proxy (see TODOS.md).

# OpenRouter API key (get one at https://openrouter.ai/keys)
EXPO_PUBLIC_OPENROUTER_API_KEY=your_key_here

# Optional: override the default models
# EXPO_PUBLIC_AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
# EXPO_PUBLIC_AI_BRIEFING_MODEL=meta-llama/llama-3.1-8b-instruct:free
